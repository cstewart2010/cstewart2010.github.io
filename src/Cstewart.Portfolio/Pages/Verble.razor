@page "/verble"
<h2 class="container">Verble</h2>

<div class="container" id="description">
    <p>
        This is a quick recreation of Worldle for when NYT eventually locks the real thing behind a paywall.
    </p>
    <p>
        You can view the results of each game in the browser console. Also, you can play multiple times a day. Have fun!
    </p>
    <div class="d-flex justify-content-evenly">
        <div class="py-2">
            <button class="btn btn-secondary" id="stats">
                Statistics
            </button>
        </div>
        <div class="py-2">
            <a class="btn btn-secondary" href="https://github.com/cstewart2010/cv/issues/new" target="_blank" rel="noopener noreferrer">
                Got any suggestions or missing words?
            </a>
        </div>
        <div class="py-2">
            <button class="btn btn-danger" id="quit">
                Give up?
            </button>
        </div>
    </div>
</div>
<div class="container my-2 w-50">
    <div id="attempts">

    </div>
</div>
<div aria-live="polite" aria-atomic="true" class="d-flex justify-content-center align-items-center w-100">
    <div class="toast my-3 text-dark" id="invalid" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="toast-body text-center">
            <span></span>
            <div class="mt-2 pt-2 border-top">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="toast">Close</button>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="end-game" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title text-center text-dark" style="text-transform: uppercase;">
              
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body text-center text-dark">
            
        </div>
      </div>
    </div>
</div>
<footer class="footer mt-auto pt-3">
    <div class="mx-auto my-auto w-50">
        <div class="d-flex justify-content-center">
            <button class="m-2 p-2 btn btn-dark" id="q">Q</button>
            <button class="m-2 p-2 btn btn-dark" id="w">W</button>
            <button class="m-2 p-2 btn btn-dark" id="e">E</button>
            <button class="m-2 p-2 btn btn-dark" id="r">R</button>
            <button class="m-2 p-2 btn btn-dark" id="t">T</button>
            <button class="m-2 p-2 btn btn-dark" id="y">Y</button>
            <button class="m-2 p-2 btn btn-dark" id="u">U</button>
            <button class="m-2 p-2 btn btn-dark" id="i">I</button>
            <button class="m-2 p-2 btn btn-dark" id="o">O</button>
            <button class="m-2 p-2 btn btn-dark" id="p">P</button>
        </div>
        <div class="d-flex justify-content-center">
            <button class="m-2 p-2 btn btn-dark" id="a">A</button>
            <button class="m-2 p-2 btn btn-dark" id="s">S</button>
            <button class="m-2 p-2 btn btn-dark" id="d">D</button>
            <button class="m-2 p-2 btn btn-dark" id="f">F</button>
            <button class="m-2 p-2 btn btn-dark" id="g">G</button>
            <button class="m-2 p-2 btn btn-dark" id="h">H</button>
            <button class="m-2 p-2 btn btn-dark" id="j">J</button>
            <button class="m-2 p-2 btn btn-dark" id="k">K</button>
            <button class="m-2 p-2 btn btn-dark" id="l">L</button>
        </div>
        <div class="d-flex justify-content-center">
            <button class="m-2 p-2 btn btn-dark" id="enter">Enter</button>
            <button class="m-2 p-2 btn btn-dark" id="z">Z</button>
            <button class="m-2 p-2 btn btn-dark" id="x">X</button>
            <button class="m-2 p-2 btn btn-dark" id="c">C</button>
            <button class="m-2 p-2 btn btn-dark" id="v">V</button>
            <button class="m-2 p-2 btn btn-dark" id="b">B</button>
            <button class="m-2 p-2 btn btn-dark" id="n">N</button>
            <button class="m-2 p-2 btn btn-dark" id="m">M</button>
            <button class="m-2 p-2 btn btn-dark" id="delete"><i class="fa-solid fa-delete-left"></i></button>                
        </div>
    </div>
</footer>

<script>
    verbleOnload();
</script>
